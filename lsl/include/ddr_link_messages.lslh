#ifndef DDR_LINK_MESSAGES_LSLH
#define DDR_LINK_MESSAGES_LSLH

// Main -> runtime
#define DDR_LM_RUNTIME_RESET 7100
#define DDR_LM_RUNTIME_START 7101
#define DDR_LM_RUNTIME_CONTROL 7102
#define DDR_LM_RUNTIME_DEBUG 7103
#define DDR_LM_RUNTIME_RESCAN_LINKS 7104
#define DDR_LM_RUNTIME_STATUS 7105

// Runtime -> main
#define DDR_LM_MAIN_READY 7200
#define DDR_LM_MAIN_FAIL 7201
#define DDR_LM_MAIN_COMPLETE 7202
#define DDR_LM_MAIN_STATUS 7203
#define DDR_LM_MAIN_SCORE_STATUS 7204 // payload: "<gaugePercent>"
#define DDR_LM_MAIN_SCORE_DEPLETED 7205

// Runtime engine -> FX
#define DDR_LM_FX_RESET 7300
#define DDR_LM_FX_NOTE 7301        // payload: "<judgement>|<combo>"
#define DDR_LM_FX_HOLD 7302        // payload: "<holdState>|<combo>"
#define DDR_LM_FX_JUDGE 7303       // payload: "<judgement>"
#define DDR_LM_FX_HOLD_JUDGE 7304  // payload: "<holdState>"
#define DDR_LM_FX_HIDE_COMBO 7305
#define DDR_LM_FX_HIDE_JUDGE 7306

// Runtime engine <-> score service
#define DDR_LM_SCORE_RESET 7400
#define DDR_LM_SCORE_START 7401    // payload: chart+song metadata json
#define DDR_LM_SCORE_NOTE 7402     // payload: "<judgement>|<flags>"
#define DDR_LM_SCORE_HOLD 7403     // payload: "<holdState>"

#define DDR_LM_SCORE_STATUS 7405

// Runtime engine <-> chart loader service
#define DDR_LM_CHART_LOAD 7500     // payload: chart URL
#define DDR_LM_CHART_CANCEL 7501   // payload: ""
#define DDR_LM_CHART_READY 7510    // payload: metadata json
#define DDR_LM_CHART_FAIL 7511     // payload: failure reason


#define DDR_BASE_URL "https://filzinrel-max.github.io/sldr"
#endif

// Relative web/screen endpoints
string DDR_PATH_SPLASH = "/web/splash.html";
string DDR_PATH_MENU = "/web/menu.html";
string DDR_PATH_SELECT = "/web/select.html";
string DDR_PATH_PLAY = "/web/play.html";
string DDR_PATH_SCORE = "/web/score.html";

// Manifest and content paths
string DDR_MANIFEST_PATH = "/game-data/song-manifest.lsl.json";

// Prim/media settings
integer DDR_MEDIA_FACE = 7;
integer DDR_ARROW_SLOTS_PER_LANE = 10;
string DDR_SIT_TEXT = "Dance";
vector DDR_SIT_TARGET_OFFSET = <-1.75, 0.0, -2>;
rotation DDR_SIT_TARGET_ROT = ZERO_ROTATION;

// Arrow lane renderer (stacked prim + client texture animation).
integer DDR_ARROW_FACE = 1; // face index on arrow lane prims (0-based)
list DDR_LANE_LINK_PREFIXES = [
    "ARROW_LANE_LEFT",
    "ARROW_LANE_DOWN",
    "ARROW_LANE_UP",
    "ARROW_LANE_RIGHT"
];
list DDR_LANE_ARROW_TEXTURES = [

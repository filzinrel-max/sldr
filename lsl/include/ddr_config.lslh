float DDR_ARROW_TEXTURE_REPEAT_X = 1.0;
float DDR_ARROW_TEXTURE_REPEAT_Y = 1.0;
float DDR_ARROW_TEXTURE_ROTATE_DEGREES = 90.0;
float DDR_ARROW_ANIM_START = 1.0;
float DDR_ARROW_ANIM_LENGTH = 1.0;
integer DDR_ARROW_ANIM_REVERSE = TRUE;
float DDR_ARROW_TRAVEL_SECONDS = 1.0;

// Judge feedback prim (set link number for the separate prim that shows hit result art).
// Set to 0 or a negative number to disable.
integer DDR_JUDGE_FEEDBACK_LINK = -1;
integer DDR_JUDGE_FEEDBACK_FACE = 1;
float DDR_JUDGE_FEEDBACK_SECONDS = 0.30;

// Texture names or UUIDs in this exact order:
// [PERFECT, GREAT, GOOD, BOO, MISS, HOLD_OK, HOLD_NG]
list DDR_JUDGE_FEEDBACK_TEXTURES = [
    "409c3b32-d0b6-66cf-cc63-a2851e06beb8",
    "0a2c8d72-34bf-48ab-30d4-78203dafa119",
    "f078614c-7ce3-81b2-8d06-75021a476762",

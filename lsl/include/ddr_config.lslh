#ifndef DDR_CONFIG_LSLH
#define DDR_CONFIG_LSLH

// Compile-time global debug default. Override in build if needed.
#ifndef DDR_DEBUG
#define DDR_DEBUG 1
#endif

// Hosted content root (GitHub Pages or raw static host)

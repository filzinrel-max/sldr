    "0923b15b-0e8d-b62d-8a52-31c9216aeeb0",
    "409c3b32-d0b6-66cf-cc63-a2851e06beb8",
    "409c3b32-d0b6-66cf-cc63-a2851e06beb8"
];

// Combo popup prim (set link number for separate prim that shows combo text).
// Set to 0 or a negative number to disable.
integer DDR_COMBO_FEEDBACK_LINK = -1;
float DDR_COMBO_FEEDBACK_SECONDS = 0.55;
integer DDR_COMBO_FEEDBACK_MIN_COMBO = 2;
float DDR_COMBO_FEEDBACK_ALPHA = 1.0;

// Combo popup colors by threshold.
vector DDR_COMBO_COLOR_LOW = <0.82, 0.95, 1.00>;    // 2-24
vector DDR_COMBO_COLOR_MID = <0.76, 1.00, 0.66>;    // 25-49
vector DDR_COMBO_COLOR_HIGH = <1.00, 0.91, 0.52>;   // 50-99
vector DDR_COMBO_COLOR_MAX = <1.00, 0.50, 0.50>;    // 100+

// Arrow motion / renderer behavior
float DDR_RENDER_LOOKAHEAD_SECONDS = 2.8;

// Runtime cadence
float DDR_TICK_SECONDS = 0.05;
float DDR_SPLASH_SECONDS = 5.0;
float DDR_PLAY_START_DELAY = 0.75;
float DDR_POST_SONG_GRACE_SECONDS = 1.25;

// Judgement windows (seconds)
float DDR_WINDOW_PERFECT = 0.045;
float DDR_WINDOW_GREAT = 0.090;
float DDR_WINDOW_GOOD = 0.135;
float DDR_WINDOW_BOO = 0.180;
float DDR_WINDOW_MISS = 0.180;

// Scoring weights
integer DDR_POINTS_PERFECT = 3;
integer DDR_POINTS_GREAT = 2;
integer DDR_POINTS_GOOD = 1;
integer DDR_POINTS_BOO = 0;
integer DDR_POINTS_MISS = -4;
integer DDR_POINTS_HOLD_OK = 2;
integer DDR_POINTS_HOLD_NG = -2;

// Grade thresholds (%)
float DDR_GRADE_A = 93.0;
float DDR_GRADE_B = 80.0;
float DDR_GRADE_C = 65.0;
float DDR_GRADE_D = 45.0;
float DDR_GRADE_E = 30.0;

// Command channel (owner only)
integer DDR_COMMAND_CHANNEL = 9919;

// Lane -> animation names. Replace with your existing animation names.
list DDR_LANE_ANIMATIONS = [
    "DDR_Left",
    "DDR_Down",
    "DDR_Up",
    "DDR_Right"
];

// Idle animation played while seated when no lane keys are held.
string DDR_IDLE_ANIMATION = "DDR_Idle";

